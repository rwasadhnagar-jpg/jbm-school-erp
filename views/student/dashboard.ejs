<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Portal — JBM School</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Segoe UI',Arial,sans-serif;background:#f4f0fa;color:#222;min-height:100vh}
    .navbar{background:#4A0E8F;color:#fff;padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 8px rgba(74,14,143,.3)}
    .navbar-brand{display:flex;align-items:center;gap:10px;font-weight:700;font-size:16px}
    .navbar-brand img{width:34px;height:34px;object-fit:contain;background:#fff;border-radius:50%;padding:2px}
    .navbar-right{display:flex;align-items:center;gap:16px;font-size:13px}
    .navbar-right a{color:rgba(255,255,255,.85);text-decoration:none}
    .navbar-right a:hover{color:#fff}
    .container{max-width:960px;margin:0 auto;padding:24px 16px}
    .welcome-banner{background:linear-gradient(135deg,#4A0E8F,#7B2FBE);color:#fff;border-radius:12px;padding:18px 22px;margin-bottom:18px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}
    .welcome-banner h2{font-size:19px;font-weight:800}
    .welcome-banner p{font-size:13px;opacity:.85;margin-top:3px}
    .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px}
    .stat-card{background:#fff;border-radius:10px;padding:14px 16px;box-shadow:0 2px 8px rgba(0,0,0,.06);border-left:4px solid #4A0E8F}
    .stat-card .stat-label{font-size:11px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:.5px}
    .stat-card .stat-value{font-size:20px;font-weight:800;color:#4A0E8F;margin-top:4px}
    .stat-card.green{border-left-color:#28a745}.stat-card.green .stat-value{color:#28a745}
    .stat-card.orange{border-left-color:#FF6B00}.stat-card.orange .stat-value{color:#FF6B00}
    .stat-card.red{border-left-color:#e53935}.stat-card.red .stat-value{color:#e53935}
    .card{background:#fff;border-radius:10px;box-shadow:0 2px 8px rgba(0,0,0,.06);margin-bottom:18px;overflow:hidden}
    .card-header{background:#4A0E8F;color:#fff;padding:11px 16px;font-weight:700;font-size:14px}
    .card-body{padding:14px 16px}
    .info-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;font-size:13px}
    .info-item{padding:7px 10px;background:#f7f3ff;border-radius:6px}
    .info-item .lbl{font-size:11px;color:#888;font-weight:600;text-transform:uppercase}
    .info-item .val{font-weight:600;color:#222;margin-top:2px}
    .fee-table{width:100%;border-collapse:collapse;font-size:13px}
    .fee-table th{background:#4A0E8F;color:#fff;padding:9px 12px;text-align:left;font-size:12px}
    .fee-table td{padding:9px 12px;border-bottom:1px solid #f0e6ff}
    .fee-table tr:last-child td{border-bottom:none}
    .fee-table tr:hover td{background:#faf5ff}
    .badge{padding:3px 10px;border-radius:12px;font-size:11px;font-weight:600}
    .badge-cash{background:#e8f5e9;color:#2e7d32}
    .badge-online,.badge-upi{background:#f3e5f5;color:#6a1b9a}
    .badge-cheque{background:#fff3e0;color:#e65100}
    .btn{display:inline-block;padding:7px 16px;border-radius:7px;font-size:13px;font-weight:600;text-decoration:none;cursor:pointer;border:none}
    .btn-purple{background:#4A0E8F;color:#fff}
    .btn-green{background:#28a745;color:#fff}
    .btn-outline{background:#fff;color:#4A0E8F;border:1.5px solid #4A0E8F}
    .btn-pay{background:linear-gradient(135deg,#FF6B00,#ff8f00);color:#fff;padding:12px 28px;font-size:15px;border-radius:10px;font-weight:800;box-shadow:0 4px 12px rgba(255,107,0,.35);transition:all .2s}
    .btn-pay:hover{transform:translateY(-2px);box-shadow:0 6px 16px rgba(255,107,0,.4)}
    .empty-state{text-align:center;padding:28px;color:#aaa;font-size:14px}
    .alert-error{background:#fff0f0;border:1px solid #ffcccc;color:#c0392b;padding:10px 14px;border-radius:6px;font-size:13px;margin-bottom:14px}
    .alert-success{background:#f0fff4;border:1px solid #b7f5c8;color:#1a7a3c;padding:10px 14px;border-radius:6px;font-size:13px;margin-bottom:14px}
    /* Tabs */
    .tabs{display:flex;gap:0;border-bottom:2px solid #4A0E8F;margin-bottom:0}
    .tab{padding:9px 18px;font-size:13px;font-weight:600;color:#888;cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;background:none;border-top:none;border-left:none;border-right:none}
    .tab.active{color:#4A0E8F;border-bottom-color:#4A0E8F;background:#f7f3ff}
    .tab-content{display:none;padding:0}
    .tab-content.active{display:block}
    .pending-badge{background:#ff9800;color:#fff;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:700}
    .verified-badge{background:#4caf50;color:#fff;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:700}
    .rejected-badge{background:#f44336;color:#fff;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:700}
    @media(max-width:640px){.stats-row{grid-template-columns:1fr 1fr}.info-grid{grid-template-columns:1fr}.welcome-banner{flex-direction:column}}
  </style>
</head>
<body>

<nav class="navbar">
  <div class="navbar-brand">
    <img src="/img/logo.png" alt="JBM">
    <span>JBM Public School</span>
    <span style="background:rgba(255,255,255,.2);padding:2px 10px;border-radius:12px;font-size:11px">Student Portal</span>
  </div>
  <div class="navbar-right">
    <span>👤 <%= student.first_name %> <%= student.last_name %></span>
    <span style="color:rgba(255,255,255,.3)">|</span>
    <a href="/portal/logout">Logout</a>
  </div>
</nav>

<div class="container">
  <% if(error&&error.length){%><div class="alert-error">⚠️ <%=error[0]%></div><%}%>
  <% if(success&&success.length){%><div class="alert-success">✅ <%=success[0]%></div><%}%>

  <!-- Welcome Banner -->
  <div class="welcome-banner">
    <div>
      <h2>Welcome, <%= student.first_name %>! 👋</h2>
      <p>Class: <%= student.class_name %> - <%= student.section %> &nbsp;|&nbsp; Adm No: <%= student.admission_no %></p>
    </div>
    <a href="/portal/pay" class="btn-pay">💳 Pay Fees Online →</a>
  </div>

  <!-- Stats -->
  <%
    const pendingOnlineTotal = onlinePay.filter(p=>p.status==='Pending').reduce((s,p)=>s+parseFloat(p.total_amount||0),0);
    const pendingCount = onlinePay.filter(p=>p.status==='Pending').length;
  %>
  <div class="stats-row">
    <div class="stat-card green">
      <div class="stat-label">Total Paid (Office)</div>
      <div class="stat-value">₹<%= Math.round(officePay.reduce((s,p)=>s+parseFloat(p.amount_paid||0),0)).toLocaleString('en-IN') %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Online Payments</div>
      <div class="stat-value"><%= onlinePay.length %></div>
    </div>
    <% if(pendingCount > 0){ %>
    <div class="stat-card orange">
      <div class="stat-label">Pending Verification</div>
      <div class="stat-value"><%= pendingCount %></div>
    </div>
    <% } else { %>
    <div class="stat-card">
      <div class="stat-label">Last Payment</div>
      <div class="stat-value" style="font-size:13px">
        <% const lastP = [...officePay,...onlinePay].sort((a,b)=>new Date(b.created_at||b.payment_date)-new Date(a.created_at||a.payment_date))[0]; %>
        <% if(lastP){ %><%= new Date(lastP.payment_date||lastP.created_at).toLocaleDateString('en-IN',{day:'2-digit',month:'short'}) %><% } else { %>—<% } %>
      </div>
    </div>
    <% } %>
    <div class="stat-card">
      <div class="stat-label">Receipts</div>
      <div class="stat-value"><%= officePay.length + onlinePay.filter(p=>p.status!=='Rejected').length %></div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start;margin-bottom:18px">
    <!-- Student Info -->
    <div class="card">
      <div class="card-header">👨‍🎓 My Details</div>
      <div class="card-body">
        <div class="info-grid">
          <div class="info-item"><div class="lbl">Full Name</div><div class="val"><%= student.first_name %> <%= student.last_name %></div></div>
          <div class="info-item"><div class="lbl">Admission No</div><div class="val"><%= student.admission_no %></div></div>
          <div class="info-item"><div class="lbl">Class</div><div class="val"><%= student.class_name %> - <%= student.section %></div></div>
          <div class="info-item"><div class="lbl">Gender</div><div class="val"><%= student.gender||'—' %></div></div>
          <% if(student.dob){ %>
          <div class="info-item"><div class="lbl">Date of Birth</div><div class="val"><%= new Date(student.dob).toLocaleDateString('en-IN',{day:'2-digit',month:'long',year:'numeric'}) %></div></div>
          <% } %>
          <% if(student.roll_no){ %>
          <div class="info-item"><div class="lbl">Roll No</div><div class="val"><%= student.roll_no %></div></div>
          <% } %>
          <% if(father){ %>
          <div class="info-item" style="grid-column:1/-1"><div class="lbl">Father's Name</div><div class="val"><%= father.first_name %> <%= father.last_name||'' %></div></div>
          <% } %>
          <% if(father&&father.mobile){ %>
          <div class="info-item"><div class="lbl">Contact</div><div class="val"><%= father.mobile %></div></div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Certificates -->
    <div class="card">
      <div class="card-header">📜 My Documents</div>
      <div class="card-body" style="padding:0">
        <% if(!certs.length){ %>
          <div class="empty-state">No documents issued yet</div>
        <% } else { %>
        <table class="fee-table">
          <thead><tr><th>Type</th><th>Serial No</th><th>Date</th><th></th></tr></thead>
          <tbody>
            <% certs.forEach(c=>{ %>
            <tr>
              <td><%= c.type %></td>
              <td style="font-family:monospace;font-size:11px"><%= c.serial_no %></td>
              <td style="font-size:12px"><%= new Date(c.issue_date).toLocaleDateString('en-IN') %></td>
              <td>
                <% if(c.type==='Marksheet'){ %>
                <a href="/certificates/marksheet/print/<%= c.id %>" target="_blank" class="btn btn-outline" style="font-size:11px;padding:3px 8px">Print</a>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Payment History (Tabbed) -->
  <div class="card">
    <div class="card-header" style="padding-bottom:0;background:#fff;color:#4A0E8F">
      <div class="tabs">
        <button class="tab active" onclick="showTab('officeTab',this)">🏫 Office Receipts (<%= officePay.length %>)</button>
        <button class="tab" onclick="showTab('onlineTab',this)">📱 Online Payments (<%= onlinePay.length %>)<% if(pendingCount>0){ %> <span class="pending-badge"><%= pendingCount %></span><% } %></button>
      </div>
    </div>

    <!-- Office Payments Tab -->
    <div id="officeTab" class="tab-content active" style="padding:0">
      <% if(!officePay.length){ %>
        <div class="empty-state">No office fee receipts yet.<br><span style="font-size:12px">Visit school office or <a href="/portal/pay" style="color:#4A0E8F;font-weight:700">Pay Online →</a></span></div>
      <% } else { %>
      <table class="fee-table">
        <thead>
          <tr>
            <th>Receipt No</th><th>Date</th><th>Amount</th><th>Mode</th><th>Remarks</th><th>Receipt</th>
          </tr>
        </thead>
        <tbody>
          <% officePay.forEach(p=>{ %>
          <tr>
            <td style="font-family:monospace;font-size:12px"><%= p.receipt_no %></td>
            <td><%= new Date(p.payment_date).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></td>
            <td><strong style="color:#4A0E8F">₹<%= Number(p.amount_paid).toLocaleString('en-IN') %></strong></td>
            <td><span class="badge badge-<%= (p.payment_mode||'cash').toLowerCase().replace(/\s+/g,'') %>"><%= p.payment_mode %></span></td>
            <td style="font-size:12px;color:#888"><%= p.remarks||'—' %></td>
            <td><a href="/portal/receipt/<%= p.id %>" target="_blank" class="btn btn-outline" style="font-size:11px;padding:3px 8px">🖨️ Print</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <div style="padding:9px 14px;background:#f7f3ff;font-size:13px;text-align:right;font-weight:700;color:#4A0E8F">
        Total Office Paid: ₹<%= Math.round(officePay.reduce((s,p)=>s+parseFloat(p.amount_paid||0),0)).toLocaleString('en-IN') %>
      </div>
      <% } %>
    </div>

    <!-- Online Payments Tab -->
    <div id="onlineTab" class="tab-content" style="padding:0">
      <% if(!onlinePay.length){ %>
        <div class="empty-state">No online payments yet.<br><a href="/portal/pay" style="color:#4A0E8F;font-weight:700">Pay Online Now →</a></div>
      <% } else { %>
      <table class="fee-table">
        <thead>
          <tr>
            <th>Receipt No</th><th>Date</th><th>Amount</th><th>Late Fee</th><th>UTR</th><th>Status</th><th>Receipt</th>
          </tr>
        </thead>
        <tbody>
          <% onlinePay.forEach(p=>{ %>
          <tr>
            <td style="font-family:monospace;font-size:11px"><%= p.receipt_no %></td>
            <td style="font-size:12px"><%= new Date(p.created_at).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></td>
            <td><strong style="color:#4A0E8F">₹<%= Number(p.total_amount).toLocaleString('en-IN') %></strong></td>
            <td style="font-size:12px;color:#e65100"><%= p.late_fee>0?'₹'+Number(p.late_fee).toLocaleString('en-IN'):'—' %></td>
            <td style="font-family:monospace;font-size:11px;max-width:120px;overflow:hidden;text-overflow:ellipsis"><%= p.utr_no %></td>
            <td>
              <% if(p.status==='Verified'){ %><span class="verified-badge">✅ Verified</span>
              <% } else if(p.status==='Rejected'){ %><span class="rejected-badge">❌ Rejected</span>
              <% } else { %><span class="pending-badge">⏳ Pending</span><% } %>
            </td>
            <td><a href="/portal/pay/receipt/<%= p.id %>" target="_blank" class="btn btn-outline" style="font-size:11px;padding:3px 8px">🖨️ Print</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <div style="padding:9px 14px;background:#f7f3ff;font-size:13px;text-align:right;font-weight:700;color:#4A0E8F">
        Total Online Paid: ₹<%= Math.round(onlinePay.filter(p=>p.status!=='Rejected').reduce((s,p)=>s+parseFloat(p.total_amount||0),0)).toLocaleString('en-IN') %>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Pay Now CTA (if no online payments) -->
  <% if(!onlinePay.length && !officePay.length){ %>
  <div style="text-align:center;padding:20px;background:#fff;border-radius:10px;box-shadow:0 2px 8px rgba(0,0,0,.06)">
    <div style="font-size:32px;margin-bottom:8px">💳</div>
    <div style="font-size:16px;font-weight:700;color:#4A0E8F;margin-bottom:8px">Pay Fees Online</div>
    <div style="font-size:13px;color:#666;margin-bottom:14px">Select months, scan UPI QR, and get instant receipt</div>
    <a href="/portal/pay" class="btn-pay">Pay Fees Now →</a>
  </div>
  <% } %>

</div>

<script>
function showTab(id, btn) {
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
}
</script>
</body>
</html>
