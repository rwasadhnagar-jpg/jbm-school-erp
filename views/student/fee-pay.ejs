<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pay Fees — JBM School</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Segoe UI',Arial,sans-serif;background:#f4f0fa;color:#222;min-height:100vh}
    .navbar{background:#4A0E8F;color:#fff;padding:0 20px;height:54px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 8px rgba(74,14,143,.3)}
    .navbar-brand{display:flex;align-items:center;gap:8px;font-weight:700;font-size:15px}
    .navbar-brand img{width:32px;height:32px;object-fit:contain;background:#fff;border-radius:50%;padding:2px}
    .navbar-right{display:flex;align-items:center;gap:14px;font-size:13px}
    .navbar-right a{color:rgba(255,255,255,.85);text-decoration:none}
    .container{max-width:900px;margin:0 auto;padding:20px 14px}
    .page-title{font-size:20px;font-weight:800;color:#4A0E8F;margin-bottom:16px;display:flex;align-items:center;gap:8px}
    .card{background:#fff;border-radius:10px;box-shadow:0 2px 10px rgba(0,0,0,.07);margin-bottom:18px;overflow:hidden}
    .card-header{background:#4A0E8F;color:#fff;padding:11px 16px;font-weight:700;font-size:14px;display:flex;align-items:center;gap:7px}
    .card-body{padding:16px}
    .alert-error{background:#fff0f0;border:1px solid #ffcccc;color:#c0392b;padding:10px 14px;border-radius:6px;font-size:13px;margin-bottom:14px}
    .alert-success{background:#f0fff4;border:1px solid #b7f5c8;color:#1a7a3c;padding:10px 14px;border-radius:6px;font-size:13px;margin-bottom:14px}
    .student-info{display:flex;gap:14px;align-items:center;padding:14px 16px;background:linear-gradient(135deg,#4A0E8F,#7B2FBE);color:#fff;border-radius:10px;margin-bottom:16px}
    .student-info .si-name{font-size:17px;font-weight:800}
    .student-info .si-sub{font-size:12px;opacity:.85;margin-top:2px}
    /* Fee table */
    .fee-table{width:100%;border-collapse:collapse;font-size:13px}
    .fee-table th{background:#f0e6ff;color:#4A0E8F;padding:9px 10px;text-align:left;font-weight:700;font-size:12px;border-bottom:2px solid #d0b8ff}
    .fee-table td{padding:9px 10px;border-bottom:1px solid #f0e6ff;vertical-align:middle}
    .fee-table tr:hover td{background:#faf5ff}
    .month-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:4px}
    .month-item{display:flex;align-items:center;gap:5px;padding:5px 8px;background:#f9f5ff;border-radius:5px;cursor:pointer;font-size:12px;border:1.5px solid #e8d8ff;transition:all .15s}
    .month-item:hover{border-color:#7B2FBE;background:#f0e6ff}
    .month-item input[type=checkbox]{accent-color:#4A0E8F;width:14px;height:14px;cursor:pointer}
    .month-item.late{border-color:#ff9800}
    .month-item.late .late-label{font-size:10px;color:#e65100;font-weight:600}
    .annual-item{display:flex;align-items:center;gap:8px;padding:8px 12px;background:#fff8e1;border-radius:6px;border:1.5px solid #ffe082;font-size:13px;margin-bottom:6px;cursor:pointer}
    .annual-item input[type=checkbox]{accent-color:#FF6B00;width:15px;height:15px;cursor:pointer}
    /* Totals panel */
    .totals-panel{background:#f7f3ff;border:2px solid #4A0E8F;border-radius:10px;padding:14px 18px}
    .total-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid #e0d0ff;font-size:13px}
    .total-row:last-child{border-bottom:none;margin-top:4px}
    .total-row.grand{font-size:18px;font-weight:800;color:#4A0E8F}
    .total-row.late-fee{color:#e65100;font-weight:600}
    /* QR section */
    .qr-section{display:none;text-align:center;padding:16px}
    .qr-section.show{display:block}
    #qrcode{display:inline-block;padding:10px;background:#fff;border:2px solid #4A0E8F;border-radius:8px;margin:10px 0}
    .upi-line{font-size:16px;font-weight:800;color:#4A0E8F;letter-spacing:1px;margin:6px 0}
    .pay-note{font-size:12px;color:#666;margin-top:6px;line-height:1.6}
    /* UTR form */
    .utr-form{display:none}
    .utr-form.show{display:block}
    .form-group{margin-bottom:12px}
    .form-group label{display:block;font-size:13px;font-weight:600;color:#333;margin-bottom:5px}
    .form-control{width:100%;padding:10px 12px;border:1.5px solid #ddd;border-radius:7px;font-size:14px;transition:border-color .2s}
    .form-control:focus{outline:none;border-color:#4A0E8F;box-shadow:0 0 0 3px rgba(74,14,143,.1)}
    .btn{display:inline-block;padding:10px 22px;border-radius:7px;font-size:14px;font-weight:700;cursor:pointer;border:none;transition:all .2s}
    .btn-purple{background:#4A0E8F;color:#fff}
    .btn-purple:hover{background:#3a0b72}
    .btn-orange{background:#FF6B00;color:#fff}
    .btn-outline{background:#fff;color:#4A0E8F;border:2px solid #4A0E8F}
    .btn-back{background:#f0e6ff;color:#4A0E8F;font-weight:600;font-size:13px;padding:7px 14px}
    .empty-note{text-align:center;padding:30px;color:#aaa;font-size:14px}
    .bank-details{background:#f9f9f9;border:1px solid #eee;border-radius:8px;padding:12px 16px;font-size:13px;line-height:2}
    .bank-details strong{color:#4A0E8F}
    @media(max-width:600px){.month-grid{grid-template-columns:repeat(2,1fr)}}
  </style>
</head>
<body>
<nav class="navbar">
  <div class="navbar-brand">
    <img src="/img/logo.png" alt="JBM">
    <span>JBM Public School</span>
    <span style="background:rgba(255,255,255,.2);padding:2px 8px;border-radius:12px;font-size:11px">Student Portal</span>
  </div>
  <div class="navbar-right">
    <a href="/portal/dashboard">← Dashboard</a>
    <span style="color:rgba(255,255,255,.3)">|</span>
    <a href="/portal/logout">Logout</a>
  </div>
</nav>

<div class="container">
  <% if(error&&error.length){%><div class="alert-error">⚠️ <%=error[0]%></div><%}%>
  <% if(success&&success.length){%><div class="alert-success">✅ <%=success[0]%></div><%}%>

  <div class="student-info">
    <div>
      <div class="si-name">💳 Pay School Fees</div>
      <div class="si-sub"><%= student.first_name %> <%= student.last_name %> &nbsp;|&nbsp; Class <%= student.class_name %>-<%= student.section %> &nbsp;|&nbsp; Adm: <%= student.admission_no %></div>
    </div>
  </div>

  <% if(!feeStructure || !feeStructure.length){ %>
  <div class="card">
    <div class="card-body">
      <div class="empty-note">
        <div style="font-size:40px;margin-bottom:10px">📋</div>
        <strong>Fee structure not set up yet</strong><br>
        <span style="font-size:12px">Please contact the school office for fee details.</span><br><br>
        <a href="/portal/dashboard" class="btn btn-outline">← Back to Dashboard</a>
      </div>
    </div>
  </div>
  <% } else { %>

  <%
    // Separate monthly and annual heads
    const monthlyHeads = feeStructure.filter(h => h.fee_type === 'Monthly');
    const annualHeads = feeStructure.filter(h => h.fee_type === 'Annual');
    // Academic year months Apr-Mar with year
    const AY_MONTHS = [
      {name:'April',short:'Apr',num:4,yr:2026},
      {name:'May',short:'May',num:5,yr:2026},
      {name:'June',short:'Jun',num:6,yr:2026},
      {name:'July',short:'Jul',num:7,yr:2026},
      {name:'August',short:'Aug',num:8,yr:2026},
      {name:'September',short:'Sep',num:9,yr:2026},
      {name:'October',short:'Oct',num:10,yr:2026},
      {name:'November',short:'Nov',num:11,yr:2026},
      {name:'December',short:'Dec',num:12,yr:2026},
      {name:'January',short:'Jan',num:1,yr:2027},
      {name:'February',short:'Feb',num:2,yr:2027},
      {name:'March',short:'Mar',num:3,yr:2027}
    ];
  %>

  <form id="feeForm" method="POST" action="/portal/pay/submit">
    <input type="hidden" name="fee_amount" id="hFeeAmt">
    <input type="hidden" name="late_fee" id="hLateFee">
    <input type="hidden" name="total_amount" id="hTotalAmt">
    <input type="hidden" name="fee_details" id="hFeeDetails">

    <!-- MONTHLY FEES -->
    <% if(monthlyHeads.length){ %>
    <div class="card">
      <div class="card-header">📅 Monthly Fees — Select Months to Pay (April 2026 – March 2027)</div>
      <div class="card-body" style="padding:0">
        <table class="fee-table">
          <thead>
            <tr>
              <th style="width:200px">Fee Head</th>
              <th style="text-align:right;width:100px">Per Month</th>
              <th>Select Months</th>
            </tr>
          </thead>
          <tbody>
          <% monthlyHeads.forEach(head => { %>
            <tr>
              <td>
                <strong><%= head.head_name %></strong>
                <% if(head.apply_late_fee){ %><br><span style="font-size:10px;color:#e65100">⚠ Late fee: ₹10/day after 10th</span><% } %>
              </td>
              <td style="text-align:right;font-weight:700;color:#4A0E8F">₹<%= Number(head.amount).toLocaleString('en-IN') %></td>
              <td>
                <div class="month-grid">
                  <% AY_MONTHS.forEach(m => { %>
                    <label class="month-item" id="ml_<%= head.fee_head_id %>_<%= m.num %>_<%= m.yr %>">
                      <input type="checkbox"
                        class="monthChk"
                        data-head-id="<%= head.fee_head_id %>"
                        data-head-name="<%= head.head_name %>"
                        data-month-num="<%= m.num %>"
                        data-month-yr="<%= m.yr %>"
                        data-month-name="<%= m.name %>"
                        data-amount="<%= head.amount %>"
                        data-apply-late="<%= head.apply_late_fee %>"
                        onchange="recalculate()">
                      <span><%= m.short %>'<%= String(m.yr).slice(2) %></span>
                    </label>
                  <% }) %>
                </div>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>

    <!-- ANNUAL FEES -->
    <% if(annualHeads.length){ %>
    <div class="card">
      <div class="card-header">📋 Annual Charges (One-time per year)</div>
      <div class="card-body">
        <% annualHeads.forEach(head => { %>
        <label class="annual-item">
          <input type="checkbox"
            class="annualChk"
            data-head-id="<%= head.fee_head_id %>"
            data-head-name="<%= head.head_name %>"
            data-amount="<%= head.amount %>"
            onchange="recalculate()">
          <div style="flex:1">
            <strong><%= head.head_name %></strong>
            <% if(head.description){ %><span style="font-size:11px;color:#888;margin-left:6px"><%= head.description %></span><% } %>
          </div>
          <strong style="color:#4A0E8F;font-size:15px">₹<%= Number(head.amount).toLocaleString('en-IN') %></strong>
        </label>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- TOTALS + QR + UTR -->
    <div class="card">
      <div class="card-header">💰 Payment Summary</div>
      <div class="card-body">
        <div class="totals-panel">
          <div class="total-row">
            <span>Fee Amount</span>
            <span id="dispFeeAmt">₹0</span>
          </div>
          <div class="total-row late-fee" id="lateFeeRow" style="display:none">
            <span>Late Fee <span id="lateFeeNote"></span></span>
            <span id="dispLateFee">₹0</span>
          </div>
          <div class="total-row grand">
            <span>Total Payable</span>
            <span id="dispTotal">₹0</span>
          </div>
        </div>

        <div id="qrSection" class="qr-section" style="margin-top:16px">
          <div id="qrcode"></div>
          <div class="upi-line">UPI: <%= config.upi_id || 'jbmpschool@sbi' %></div>
          <div class="pay-note">
            Scan QR with <strong>PhonePe / GPay / Paytm / Any UPI App</strong><br>
            Amount will be pre-filled. Pay and note the <strong>UTR / Transaction ID</strong>.
          </div>

          <!-- Bank details -->
          <div class="bank-details" style="margin-top:12px;text-align:left">
            <div style="font-weight:700;margin-bottom:6px;color:#4A0E8F">🏦 Bank Transfer Details</div>
            <div><strong>Account Name:</strong> <%= config.account_holder || '—' %></div>
            <div><strong>Bank:</strong> <%= config.bank_name || '—' %></div>
            <div><strong>Account No:</strong> <%= config.account_no || '—' %></div>
            <div><strong>IFSC:</strong> <%= config.ifsc_code || '—' %></div>
            <div><strong>Branch:</strong> <%= config.branch_name || '—' %></div>
          </div>

          <% if(config.payment_note){ %>
          <div style="margin-top:10px;font-size:12px;color:#777;background:#fff8e1;padding:8px 12px;border-radius:6px;border-left:3px solid #FF6B00">
            ℹ️ <%= config.payment_note %>
          </div>
          <% } %>
        </div>

        <!-- UTR Entry -->
        <div id="utrSection" class="utr-form" style="margin-top:16px">
          <div class="form-group">
            <label>UTR / Transaction Reference Number *</label>
            <input type="text" name="utr_no" class="form-control" placeholder="Enter 12-digit UTR or Transaction ID after payment" required style="font-size:15px;font-weight:600;letter-spacing:1px">
            <div style="font-size:11px;color:#888;margin-top:4px">Find UTR in your bank app under transaction details</div>
          </div>
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <button type="submit" class="btn btn-purple">✅ Confirm Payment & Get Receipt</button>
            <a href="/portal/dashboard" class="btn btn-outline">Cancel</a>
          </div>
        </div>

        <div id="selectPrompt" style="text-align:center;padding:20px;color:#aaa;font-size:14px">
          ☝️ Select fees above to see total and payment QR
        </div>
      </div>
    </div>

  </form>
  <% } %>

  <!-- Recent Online Payments -->
  <% if(paidPayments && paidPayments.length){ %>
  <div class="card">
    <div class="card-header">🕐 Recent Online Payment Requests</div>
    <div class="card-body" style="padding:0">
      <table class="fee-table">
        <thead><tr><th>Receipt No</th><th>Date</th><th>Amount</th><th>UTR</th><th>Status</th><th></th></tr></thead>
        <tbody>
        <% paidPayments.forEach(p => { %>
          <tr>
            <td style="font-family:monospace;font-size:12px"><%= p.receipt_no %></td>
            <td style="font-size:12px"><%= new Date(p.created_at).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></td>
            <td><strong style="color:#4A0E8F">₹<%= Number(p.total_amount).toLocaleString('en-IN') %></strong></td>
            <td style="font-family:monospace;font-size:12px"><%= p.utr_no %></td>
            <td>
              <span style="padding:3px 10px;border-radius:12px;font-size:11px;font-weight:700;
                background:<%= p.status==='Verified'?'#e8f5e9':p.status==='Rejected'?'#ffebee':'#fff3e0' %>;
                color:<%= p.status==='Verified'?'#2e7d32':p.status==='Rejected'?'#c62828':'#e65100' %>">
                <%= p.status==='Verified'?'✅ Verified':p.status==='Rejected'?'❌ Rejected':'⏳ Pending' %>
              </span>
            </td>
            <td><a href="/portal/pay/receipt/<%= p.id %>" target="_blank" class="btn btn-outline" style="font-size:11px;padding:3px 8px">🖨️</a></td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

</div>

<script>
const UPI_ID = '<%= (config.upi_id||"jbmpschool@sbi").replace(/'/g,"") %>';
const UPI_NAME = '<%= (config.upi_name||"JBM Public School").replace(/'/g,"") %>';
const STUDENT_ADM = '<%= student.admission_no %>';
let qrGenerated = false;
let qrInstance = null;

function recalculate() {
  const today = new Date();
  const todayDay = today.getDate();
  const todayMonth = today.getMonth() + 1;
  const todayYear = today.getFullYear();

  let feeAmt = 0;
  let lateFee = 0;
  const details = [];

  // Monthly checkboxes
  document.querySelectorAll('.monthChk:checked').forEach(chk => {
    const amt = parseFloat(chk.dataset.amount);
    const mNum = parseInt(chk.dataset.monthNum);
    const mYr = parseInt(chk.dataset.monthYr);
    const applyLate = chk.dataset.applyLate === '1';
    feeAmt += amt;
    details.push({ type: 'Monthly', head: chk.dataset.headName, month: chk.dataset.monthName, year: mYr, amount: amt });

    // Late fee: after 10th of that month, Rs10/day, only for apply_late_fee heads
    if (applyLate) {
      const dueDate = new Date(mYr, mNum - 1, 10);
      if (today > dueDate) {
        const msDay = 24 * 60 * 60 * 1000;
        const daysLate = Math.floor((today - dueDate) / msDay);
        lateFee += daysLate * 10;
      }
    }
  });

  // Annual checkboxes
  document.querySelectorAll('.annualChk:checked').forEach(chk => {
    const amt = parseFloat(chk.dataset.amount);
    feeAmt += amt;
    details.push({ type: 'Annual', head: chk.dataset.headName, amount: amt });
  });

  const total = feeAmt + lateFee;

  // Update display
  document.getElementById('dispFeeAmt').textContent = '₹' + feeAmt.toLocaleString('en-IN', {minimumFractionDigits:0});
  document.getElementById('dispLateFee').textContent = '₹' + lateFee.toLocaleString('en-IN', {minimumFractionDigits:0});
  document.getElementById('dispTotal').textContent = '₹' + total.toLocaleString('en-IN', {minimumFractionDigits:0});

  document.getElementById('lateFeeRow').style.display = lateFee > 0 ? '' : 'none';
  if (lateFee > 0) {
    document.getElementById('lateFeeNote').textContent = '(₹10/day × days after 10th)';
  }

  // Hidden fields
  document.getElementById('hFeeAmt').value = feeAmt.toFixed(2);
  document.getElementById('hLateFee').value = lateFee.toFixed(2);
  document.getElementById('hTotalAmt').value = total.toFixed(2);
  document.getElementById('hFeeDetails').value = JSON.stringify(details);

  const qrSection = document.getElementById('qrSection');
  const utrSection = document.getElementById('utrSection');
  const selectPrompt = document.getElementById('selectPrompt');

  if (total > 0) {
    qrSection.classList.add('show');
    utrSection.classList.add('show');
    selectPrompt.style.display = 'none';
    generateQR(total);
  } else {
    qrSection.classList.remove('show');
    utrSection.classList.remove('show');
    selectPrompt.style.display = '';
    qrGenerated = false;
    if (qrInstance) { document.getElementById('qrcode').innerHTML = ''; qrInstance = null; }
  }
}

function generateQR(amount) {
  const upiUrl = `upi://pay?pa=${UPI_ID}&pn=${encodeURIComponent(UPI_NAME)}&am=${amount.toFixed(2)}&cu=INR&tn=${encodeURIComponent('Fee ' + STUDENT_ADM)}`;
  const container = document.getElementById('qrcode');
  container.innerHTML = '';
  try {
    qrInstance = new QRCode(container, {
      text: upiUrl,
      width: 180,
      height: 180,
      colorDark: '#4A0E8F',
      colorLight: '#ffffff',
      correctLevel: QRCode.CorrectLevel.M
    });
  } catch(e) {
    container.innerHTML = '<div style="padding:20px;color:#888;font-size:12px">QR generation failed.<br>Use UPI ID directly.</div>';
  }
}

// Highlight late months
(function markLateMonths() {
  const today = new Date();
  document.querySelectorAll('.monthChk').forEach(chk => {
    const mNum = parseInt(chk.dataset.monthNum);
    const mYr = parseInt(chk.dataset.monthYr);
    if (chk.dataset.applyLate === '1') {
      const dueDate = new Date(mYr, mNum - 1, 10);
      if (today > dueDate) {
        const label = chk.closest('.month-item');
        if (label) {
          label.classList.add('late');
          label.title = 'Late fee applies (₹10/day after 10th)';
        }
      }
    }
  });
})();
</script>
</body>
</html>
