<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>TC — <%= cert.serial_no %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Times New Roman', Times, serif; background: #f0f0f0; color: #111; font-size: 14px; }

    .tc-wrapper {
      max-width: 800px;
      margin: 30px auto;
      background: #fff;
      border: 3px double #4A0E8F;
      padding: 30px 40px;
    }

    /* Header */
    .tc-header { display: flex; align-items: center; gap: 18px; margin-bottom: 18px; border-bottom: 2px solid #4A0E8F; padding-bottom: 14px; }
    .tc-header-logo img { width: 80px; height: 80px; object-fit: contain; }
    .tc-header-text { flex: 1; text-align: center; }
    .tc-header h1 { font-size: 26px; color: #4A0E8F; letter-spacing: 2px; font-weight: 800; }
    .tc-header h2 { font-size: 14px; color: #333; font-weight: 600; margin-top: 3px; }
    .tc-header p { font-size: 12px; color: #555; margin-top: 3px; line-height: 1.6; }

    .tc-title { text-align: center; font-size: 20px; font-weight: bold; color: #4A0E8F; letter-spacing: 3px; text-decoration: underline; margin: 16px 0 20px; }

    .serial-row { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 18px; }

    .tc-table { width: 100%; border-collapse: collapse; margin-bottom: 18px; }
    .tc-table tr td { padding: 7px 4px; border-bottom: 1px dotted #ccc; vertical-align: top; line-height: 1.6; }
    .tc-table tr td:first-child { width: 45%; font-style: italic; }
    .tc-table tr td:nth-child(2) { width: 5%; text-align: center; }
    .tc-table tr td:last-child { font-weight: bold; text-decoration: underline; }

    .tc-declaration { font-size: 12.5px; color: #444; line-height: 1.8; margin: 16px 0; border-top: 1px solid #ccc; padding-top: 12px; }

    .tc-footer { display: flex; justify-content: space-between; margin-top: 40px; font-size: 13px; }
    .sig-block { text-align: center; }
    .sig-line { border-top: 1px solid #333; width: 160px; margin: 36px auto 4px; }

    .print-actions { text-align: center; padding: 16px; background: #f5f5f5; display: flex; gap: 10px; justify-content: center; }
    .btn-print { background: #4A0E8F; color: #fff; border: none; padding: 10px 28px; border-radius: 6px; font-size: 14px; cursor: pointer; font-weight: 600; }
    .btn-close { background: #fff; color: #4A0E8F; border: 2px solid #4A0E8F; padding: 10px 24px; border-radius: 6px; font-size: 14px; cursor: pointer; font-weight: 600; }

    @media print {
      body { background: #fff; }
      .print-actions { display: none; }
      .tc-wrapper { margin: 0; border: 3px double #4A0E8F; }
    }
  </style>
</head>
<body>

<div class="tc-wrapper">
  <div class="tc-header">
    <div class="tc-header-logo">
      <img src="/img/logo.png" alt="JBM Logo">
    </div>
    <div class="tc-header-text">
      <h1>JBM PUBLIC SCHOOL</h1>
      <h2>RZ 666/1, 3&4 Nasirpur Road, Sadh Nagar, Palam, New Delhi - 110045</h2>
      <p>Ph: 9868337627 | 9891251352 &nbsp;|&nbsp; Email: jbmpschool@gmail.com &nbsp;|&nbsp; www.jbmpschool.com</p>
      <p>CBSE Affiliation No: <strong>2730708</strong> &nbsp;|&nbsp; School ID: <strong>1821201</strong></p>
    </div>
  </div>

  <div class="tc-title">TRANSFER CERTIFICATE</div>

  <div class="serial-row">
    <span>Serial No.: <strong><%= cert.serial_no %></strong></span>
    <span>Date of Issue: <strong><%= new Date(cert.issue_date).toLocaleDateString('en-IN', {day:'2-digit',month:'long',year:'numeric'}) %></strong></span>
  </div>

  <table class="tc-table">
    <tr>
      <td>1. Name of the Student</td><td>:</td>
      <td><%= cert.first_name %> <%= cert.last_name %></td>
    </tr>
    <tr>
      <td>2. Father's Name</td><td>:</td>
      <td><%= cert.father_name || '—' %> <%= cert.father_last || '' %></td>
    </tr>
    <tr>
      <td>3. Admission Number</td><td>:</td>
      <td><%= cert.admission_no %></td>
    </tr>
    <tr>
      <td>4. Date of Birth (as per records)</td><td>:</td>
      <td><%= cert.dob ? new Date(cert.dob).toLocaleDateString('en-IN', {day:'2-digit',month:'long',year:'numeric'}) : '—' %></td>
    </tr>
    <% if(cert.data.dob_words) { %>
    <tr>
      <td>5. Date of Birth in Words</td><td>:</td>
      <td><%= cert.data.dob_words %></td>
    </tr>
    <% } %>
    <tr>
      <td><%= cert.data.dob_words ? 6 : 5 %>. Gender</td><td>:</td>
      <td><%= cert.gender || '—' %></td>
    </tr>
    <tr>
      <td><%= cert.data.dob_words ? 7 : 6 %>. Class Last Studied</td><td>:</td>
      <td><%= cert.data.last_class || cert.class_name || '—' %> <%= !cert.data.last_class ? (cert.section||'') : '' %></td>
    </tr>
    <% if(cert.data.leaving_date) { %>
    <tr>
      <td>Date of Leaving School</td><td>:</td>
      <td><%= new Date(cert.data.leaving_date).toLocaleDateString('en-IN') %></td>
    </tr>
    <% } %>
    <tr>
      <td>Result / Exam Passed</td><td>:</td>
      <td><%= cert.data.result || '—' %></td>
    </tr>
    <tr>
      <td>Reason for Leaving</td><td>:</td>
      <td><%= cert.data.reason || '—' %></td>
    </tr>
    <tr>
      <td>Conduct</td><td>:</td>
      <td><%= cert.data.conduct || 'Good' %></td>
    </tr>
    <% if(cert.data.remarks) { %>
    <tr>
      <td>Remarks</td><td>:</td>
      <td><%= cert.data.remarks %></td>
    </tr>
    <% } %>
  </table>

  <div class="tc-declaration">
    This is to certify that the above named student was a bonafide student of this school. The particulars mentioned above have been verified from the school records and found to be correct.
  </div>

  <div class="tc-footer">
    <div class="sig-block">
      <div class="sig-line"></div>
      <div>Class Teacher</div>
    </div>
    <div class="sig-block">
      <div class="sig-line"></div>
      <div>Examination Incharge</div>
    </div>
    <div class="sig-block">
      <div class="sig-line"></div>
      <div>Principal / Head of School</div>
    </div>
  </div>

  <p style="text-align:center;font-size:11px;color:#aaa;margin-top:24px">Issued by: <%= cert.issued_by_name || 'Admin' %> | Printed on: <%= new Date().toLocaleDateString('en-IN') %></p>
</div>

<div class="print-actions">
  <button class="btn-print" onclick="window.print()">🖨️ Print TC</button>
  <a href="/certificates" style="text-decoration:none"><button class="btn-close">← Back to List</button></a>
</div>

</body>
</html>
