<%- include('../partials/header', { title: 'Issue Bonafide', activePage: 'certificates' }) %>
<div class="page-header"><div><h1>📄 Issue Bonafide Certificate</h1><div class="breadcrumb"><a href="/certificates" style="color:rgba(255,255,255,0.8)">Certificates</a> → Bonafide</div></div></div>

<div class="form-card" style="max-width:600px">
  <div class="form-card-header">📄 Bonafide Certificate Form</div>
  <div class="form-card-body">
    <form method="POST" action="/certificates/bonafide/issue">
      <div class="form-group" style="margin-bottom:14px">
        <label>Select Student <span class="required">*</span></label>
        <select name="student_id" class="form-control" required>
          <option value="">-- Select Student --</option>
          <% students.forEach(s => { %><option value="<%= s.id %>"><%= s.first_name %> <%= s.last_name %> | <%= s.admission_no %> | <%= s.class_name||'' %> <%= s.section||'' %></option><% }) %>
        </select>
      </div>
      <div class="form-group" style="margin-bottom:14px">
        <label>Issue Date <span class="required">*</span></label>
        <input type="date" name="issue_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>" required>
      </div>
      <div class="form-group" style="margin-bottom:14px">
        <label>Purpose of Certificate</label>
        <select name="purpose" class="form-control">
          <option>Bank Account Opening</option>
          <option>Scholarship Application</option>
          <option>Passport Application</option>
          <option>Visa / Travel</option>
          <option>RTE / Government Scheme</option>
          <option>Employment / Job</option>
          <option>General Purpose</option>
        </select>
      </div>
      <div class="form-group" style="margin-bottom:14px">
        <label>Additional Remarks</label>
        <textarea name="remarks" class="form-control" rows="2" placeholder="Any additional remarks..."></textarea>
      </div>
      <div style="display:flex;gap:10px;margin-top:8px">
        <button type="submit" class="btn btn-purple">📄 Issue & Print</button>
        <a href="/certificates" class="btn btn-outline-purple">Cancel</a>
      </div>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
