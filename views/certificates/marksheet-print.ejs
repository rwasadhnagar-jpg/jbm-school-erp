<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Marksheet — <%= cert.serial_no %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #f0f0f0; color: #111; font-size: 13px; }

    .ms-wrapper {
      max-width: 760px;
      margin: 30px auto;
      background: #fff;
      border: 3px solid #4A0E8F;
      border-radius: 4px;
      overflow: hidden;
    }

    .ms-header { background: #fff; color: #111; display: flex; align-items: center; gap: 16px; padding: 14px 20px; border-bottom: 3px solid #4A0E8F; }
    .ms-header-logo img { width: 70px; height: 70px; object-fit: contain; }
    .ms-header-text { flex: 1; text-align: center; }
    .ms-header h1 { font-size: 22px; letter-spacing: 1px; color: #4A0E8F; font-weight: 800; }
    .ms-header h2 { font-size: 12px; color: #333; font-weight: 600; margin-top: 2px; }
    .ms-header p { font-size: 11px; color: #555; margin-top: 2px; line-height: 1.5; }

    .exam-banner { background: #FF6B00; color: #fff; text-align: center; padding: 7px; font-size: 15px; font-weight: 700; letter-spacing: 2px; }

    .ms-body { padding: 20px 28px; }

    .ms-meta { display: flex; justify-content: space-between; margin-bottom: 14px; font-size: 13px; }
    .ms-meta span strong { color: #4A0E8F; }

    .student-info { background: #f7f3ff; border: 1px solid #d0b8f5; border-radius: 6px; padding: 12px 16px; margin-bottom: 16px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; font-size: 13px; }
    .student-info div span:first-child { color: #666; }
    .student-info div span:last-child { font-weight: 600; }

    .marks-table { width: 100%; border-collapse: collapse; margin-bottom: 14px; }
    .marks-table th { background: #4A0E8F; color: #fff; padding: 8px 10px; text-align: left; font-size: 13px; }
    .marks-table th:not(:first-child) { text-align: center; }
    .marks-table td { padding: 7px 10px; border-bottom: 1px solid #eee; }
    .marks-table td:not(:first-child) { text-align: center; }
    .marks-table tr:nth-child(even) td { background: #faf8ff; }
    .marks-table .total-row td { background: #4A0E8F !important; color: #fff; font-weight: 700; }

    .grade-badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-weight: 700; font-size: 13px; }
    .grade-A-plus { background: #28a745; color: #fff; }
    .grade-A { background: #20c997; color: #fff; }
    .grade-B { background: #007bff; color: #fff; }
    .grade-C { background: #fd7e14; color: #fff; }
    .grade-D { background: #ffc107; color: #000; }
    .grade-F { background: #dc3545; color: #fff; }

    .result-row { display: flex; gap: 20px; align-items: center; background: #f7f3ff; border: 1px solid #d0b8f5; border-radius: 6px; padding: 12px 16px; margin-bottom: 14px; }
    .result-big { font-size: 20px; font-weight: 800; }
    .result-PASS { color: #28a745; }
    .result-FAIL { color: #dc3545; }

    .ms-footer { display: flex; justify-content: space-between; border-top: 1px dashed #ccc; padding-top: 14px; font-size: 12px; }
    .sig-block { text-align: center; }
    .sig-line { border-top: 1px solid #555; width: 130px; margin: 32px auto 4px; }

    .print-actions { text-align: center; padding: 16px; background: #f5f5f5; display: flex; gap: 10px; justify-content: center; }
    .btn-print { background: #4A0E8F; color: #fff; border: none; padding: 10px 28px; border-radius: 6px; font-size: 14px; cursor: pointer; font-weight: 600; }
    .btn-close { background: #fff; color: #4A0E8F; border: 2px solid #4A0E8F; padding: 10px 24px; border-radius: 6px; font-size: 14px; cursor: pointer; font-weight: 600; }

    @media print {
      body { background: #fff; }
      .print-actions { display: none; }
      .ms-wrapper { margin: 0; }
    }
  </style>
</head>
<body>

<div class="ms-wrapper">
  <div class="ms-header">
    <div class="ms-header-logo">
      <img src="/img/logo.png" alt="JBM Logo">
    </div>
    <div class="ms-header-text">
      <h1>JBM PUBLIC SCHOOL</h1>
      <h2>RZ 666/1, 3&4 Nasirpur Road, Sadh Nagar, Palam, New Delhi - 110045</h2>
      <p>Ph: 9868631661 | 9891251352 &nbsp;|&nbsp; Email: jbmpschool@gmail.com &nbsp;|&nbsp; www.jbmpschool.com</p>
      <p>CBSE Affiliation No: <strong>2730708</strong> &nbsp;|&nbsp; School ID: <strong>1821201</strong> &nbsp;|&nbsp; AY: <%= cert.data.academic_year %></p>
    </div>
  </div>
  <div class="exam-banner"><%= cert.data.exam_name.toUpperCase() %> — REPORT CARD</div>

  <div class="ms-body">
    <div class="ms-meta">
      <span>Marksheet No.: <strong><%= cert.serial_no %></strong></span>
      <span>Issue Date: <strong><%= new Date(cert.issue_date).toLocaleDateString('en-IN') %></strong></span>
    </div>

    <div class="student-info">
      <div><span>Student Name: </span><span><%= cert.first_name %> <%= cert.last_name %></span></div>
      <div><span>Admission No.: </span><span><%= cert.admission_no %></span></div>
      <div><span>Roll No.: </span><span><%= cert.roll_no || '—' %></span></div>
      <div><span>Class: </span><span><%= cert.class_name||'—' %> - <%= cert.section||'' %></span></div>
      <div><span>Father's Name: </span><span><%= cert.father_name || '—' %></span></div>
      <div><span>Gender: </span><span><%= cert.gender || '—' %></span></div>
    </div>

    <table class="marks-table">
      <thead>
        <tr><th>#</th><th>Subject</th><th>Max Marks</th><th>Marks Obtained</th><th>%</th><th>Grade</th></tr>
      </thead>
      <tbody>
        <% cert.data.subjects.forEach((sub, i) => {
          const pct = sub.max > 0 ? ((sub.obt/sub.max)*100).toFixed(1) : 0;
          let g = 'F';
          if(pct>=90) g='A+'; else if(pct>=75) g='A'; else if(pct>=60) g='B'; else if(pct>=45) g='C'; else if(pct>=33) g='D';
        %>
        <tr>
          <td><%= i+1 %></td>
          <td><strong><%= sub.name %></strong></td>
          <td><%= sub.max %></td>
          <td><strong><%= sub.obt %></strong></td>
          <td><%= pct %>%</td>
          <td><span class="grade-badge grade-<%= g.replace('+','A-plus') %>"><%= g %></span></td>
        </tr>
        <% }) %>
        <tr class="total-row">
          <td colspan="2">TOTAL</td>
          <td><%= cert.data.totalMax %></td>
          <td><%= cert.data.totalObt %></td>
          <td><%= cert.data.percentage %>%</td>
          <td><span class="grade-badge" style="background:#fff;color:#4A0E8F"><%= cert.data.grade %></span></td>
        </tr>
      </tbody>
    </table>

    <div class="result-row">
      <div>
        <div style="font-size:12px;color:#666;margin-bottom:4px">Overall Result</div>
        <div class="result-big result-<%= cert.data.result %>"><%= cert.data.result %></div>
      </div>
      <div>
        <div style="font-size:12px;color:#666;margin-bottom:4px">Percentage</div>
        <div style="font-size:20px;font-weight:700"><%= cert.data.percentage %>%</div>
      </div>
      <div>
        <div style="font-size:12px;color:#666;margin-bottom:4px">Grade</div>
        <div style="font-size:20px;font-weight:700"><%= cert.data.grade %></div>
      </div>
      <% if(cert.data.remarks) { %>
      <div style="flex:1">
        <div style="font-size:12px;color:#666;margin-bottom:4px">Remarks</div>
        <div style="font-style:italic"><%= cert.data.remarks %></div>
      </div>
      <% } %>
    </div>

    <div class="ms-footer">
      <div class="sig-block"><div class="sig-line"></div><div>Class Teacher</div></div>
      <div class="sig-block"><div class="sig-line"></div><div>Exam Incharge</div></div>
      <div class="sig-block"><div class="sig-line"></div><div>Principal</div></div>
    </div>

    <p style="text-align:center;font-size:11px;color:#aaa;margin-top:14px">Issued by: <%= cert.issued_by_name||'Admin' %> | Printed: <%= new Date().toLocaleDateString('en-IN') %> | Computer Generated</p>
  </div>
</div>

<div class="print-actions">
  <button class="btn-print" onclick="window.print()">🖨️ Print Marksheet</button>
  <a href="/certificates" style="text-decoration:none"><button class="btn-close">← Back to List</button></a>
</div>

</body>
</html>
