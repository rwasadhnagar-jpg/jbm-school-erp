<%- include('../partials/header', { title: student.first_name + ' ' + student.last_name, activePage: 'students' }) %>

<div class="page-header">
  <div>
    <h1>👤 <%= student.first_name %> <%= student.middle_name || '' %> <%= student.last_name %></h1>
    <div class="breadcrumb"><a href="/studentadministration" style="color:rgba(255,255,255,0.8)">Students</a> → View Profile</div>
  </div>
</div>

<div style="display:flex;gap:16px;margin-bottom:16px;flex-wrap:wrap">
  <a href="/studentadministration/edit/<%= student.id %>" class="btn btn-purple">✏️ Edit Student</a>
  <a href="/studentadministration" class="btn btn-outline-purple">← Back to List</a>
  <form method="POST" action="/studentadministration/delete/<%= student.id %>" style="display:inline" onsubmit="return confirm('Deactivate this student?')">
    <button type="submit" class="btn btn-outline-red">🗑 Deactivate</button>
  </form>
</div>

<div class="dashboard-row col-2">
  <!-- Personal Info -->
  <div class="form-card">
    <div class="form-card-header">👤 Personal Details</div>
    <div class="form-card-body">
      <% if(student.photo) { %>
        <img src="<%= student.photo %>" style="width:100px;height:100px;border-radius:50%;object-fit:cover;border:3px solid var(--purple);margin-bottom:12px">
      <% } %>
      <table style="width:100%;font-size:13px">
        <tr><td style="color:#888;width:40%;padding:5px 0">Admission No.</td><td><strong><%= student.admission_no %></strong></td></tr>
        <tr><td style="color:#888;padding:5px 0">Roll No.</td><td><%= student.roll_no || '—' %></td></tr>
        <tr><td style="color:#888;padding:5px 0">Class</td><td><strong><%= student.class_name || '—' %> <%= student.section || '' %></strong></td></tr>
        <tr><td style="color:#888;padding:5px 0">Admission Date</td><td><%= student.admission_date ? moment(student.admission_date).format('DD MMM YYYY') : '—' %></td></tr>
        <tr><td style="color:#888;padding:5px 0">Gender</td><td><%= student.gender || '—' %></td></tr>
        <tr><td style="color:#888;padding:5px 0">Date of Birth</td><td><%= student.dob ? moment(student.dob).format('DD MMM YYYY') : '—' %></td></tr>
        <tr><td style="color:#888;padding:5px 0">Blood Group</td><td><%= student.blood_group || '—' %></td></tr>
        <tr><td style="color:#888;padding:5px 0">Category</td><td><%= student.category %></td></tr>
        <tr><td style="color:#888;padding:5px 0">Religion</td><td><%= student.religion || '—' %></td></tr>
        <tr><td style="color:#888;padding:5px 0">Nationality</td><td><%= student.nationality %></td></tr>
        <tr><td style="color:#888;padding:5px 0">Aadhar No.</td><td><%= student.aadhar_no || '—' %></td></tr>
        <tr><td style="color:#888;padding:5px 0">Status</td><td>
          <% if(student.status==='active') { %><span class="badge badge-green">Active</span>
          <% } else { %><span class="badge badge-grey"><%= student.status %></span><% } %>
        </td></tr>
      </table>
    </div>
  </div>

  <!-- Parents -->
  <div class="form-card">
    <div class="form-card-header">👨 Parents / Guardian</div>
    <div class="form-card-body">
      <% const father = parents.find(p => p.type === 'father'); %>
      <% const mother = parents.find(p => p.type === 'mother'); %>
      <% if(father) { %>
        <div style="margin-bottom:16px">
          <div style="font-weight:700;color:var(--purple);margin-bottom:6px">👨 Father</div>
          <table style="width:100%;font-size:13px">
            <tr><td style="color:#888;width:40%;padding:3px 0">Name</td><td><strong><%= father.first_name %> <%= father.last_name || '' %></strong></td></tr>
            <tr><td style="color:#888;padding:3px 0">Mobile</td><td><%= father.mobile || '—' %></td></tr>
            <tr><td style="color:#888;padding:3px 0">Occupation</td><td><%= father.occupation || '—' %></td></tr>
            <tr><td style="color:#888;padding:3px 0">Email</td><td><%= father.email || '—' %></td></tr>
          </table>
        </div>
      <% } %>
      <% if(mother) { %>
        <div>
          <div style="font-weight:700;color:var(--purple);margin-bottom:6px">👩 Mother</div>
          <table style="width:100%;font-size:13px">
            <tr><td style="color:#888;width:40%;padding:3px 0">Name</td><td><strong><%= mother.first_name %> <%= mother.last_name || '' %></strong></td></tr>
            <tr><td style="color:#888;padding:3px 0">Mobile</td><td><%= mother.mobile || '—' %></td></tr>
            <tr><td style="color:#888;padding:3px 0">Occupation</td><td><%= mother.occupation || '—' %></td></tr>
          </table>
        </div>
      <% } %>
      <% if(!father && !mother) { %><div class="no-data">No parent details added</div><% } %>
    </div>
  </div>
</div>

<!-- Fee History -->
<div class="table-container" style="margin-bottom:16px">
  <div class="table-header"><h3>💰 Recent Fee Payments</h3><a href="/feemanagement?student_id=<%= student.id %>" class="btn btn-outline-purple btn-sm">View All</a></div>
  <table>
    <thead><tr><th>Receipt No.</th><th>Amount</th><th>Date</th><th>Mode</th><th>Remarks</th></tr></thead>
    <tbody>
      <% if(feeHistory.length) { %>
        <% feeHistory.forEach(f => { %>
        <tr>
          <td><%= f.receipt_no || '—' %></td>
          <td>₹<%= Number(f.amount_paid).toLocaleString('en-IN') %></td>
          <td><%= moment(f.payment_date).format('DD MMM YYYY') %></td>
          <td><span class="badge badge-blue"><%= f.payment_mode %></span></td>
          <td><%= f.remarks || '—' %></td>
        </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="5" class="no-data">No fee payments found</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
