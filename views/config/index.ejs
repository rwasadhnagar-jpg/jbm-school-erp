<%- include('../partials/header', { title: 'Configuration', activePage: 'config' }) %>
<div class='page-header'><div><h1>⚙️ Configuration</h1></div></div>
<form method='POST' action='/configuration/save'>
<div class='form-card'>
  <div class='form-card-header'>⚙️ School Settings</div>
  <div class='form-card-body'>
    <div class='form-grid'>
      <% config.forEach(c => { %>
      <div class='form-group'>
        <label><%= c.description || c.key_name %></label>
        <input type='text' name='<%= c.key_name %>' class='form-control' value='<%= c.value || "" %>'>
      </div>
      <% }) %>
    </div>
  </div>
  <div class='form-actions'><button type='submit' class='btn btn-purple'>💾 Save Settings</button></div>
</div>
</form>
<%- include('../partials/footer') %>