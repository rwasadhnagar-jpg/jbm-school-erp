<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — JBM School ERP</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="login-page">
  <div class="login-box">
    <div class="login-logo">
      <div class="logo-circle">🏫</div>
      <div class="school-name">JBM Public School</div>
      <div class="erp-label">School Management System</div>
    </div>

    <% if (error && error.length) { %>
      <div class="alert alert-error">⚠️ <%= error[0] %></div>
    <% } %>

    <form method="POST" action="/login">
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="Enter your email" required autofocus>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" class="form-control" placeholder="Enter password" required>
      </div>
      <button type="submit" class="login-btn">🔐 Sign In</button>
    </form>

    <div class="login-footer">
      Academic Year: <strong><%= academicYear %></strong><br>
      &copy; 2026 JBM Public School — ERP v1.0
    </div>
  </div>
</div>
</body>
</html>
