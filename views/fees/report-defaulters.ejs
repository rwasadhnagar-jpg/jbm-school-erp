<%- include('../partials/header', { title: 'Fee Defaulters', activePage: 'fees' }) %>
<div class="page-header"><div><h1>⚠️ Fee Defaulter List</h1><div class="breadcrumb">Fee Management → Defaulters</div></div></div>
<div class="toolbar">
  <form method="GET" action="/feemanagement/reports/defaulters" style="display:flex;gap:8px;align-items:center">
    <select name="class_id" class="form-control form-control-sm" style="width:180px">
      <option value="">All Classes</option>
      <% classes.forEach(c => { %><option value="<%= c.id %>" <%= class_id==c.id?'selected':'' %>><%= c.class_name %> - <%= c.section %></option><% }) %>
    </select>
    <button type="submit" class="btn btn-purple btn-sm">Filter</button>
    <a href="/feemanagement" class="btn btn-outline-purple btn-sm">← Back</a>
  </form>
</div>
<div class="table-container">
  <div class="table-header"><h3>Students with Zero Fee Payment</h3><span class="badge badge-red"><%= defaulters.length %> Defaulters</span></div>
  <table>
    <thead><tr><th>#</th><th>Student</th><th>Adm No.</th><th>Class</th><th>Father</th><th>Mobile</th><th>Total Paid</th><th>Action</th></tr></thead>
    <tbody>
      <% if(defaulters.length) { defaulters.forEach((d,i) => { %>
      <tr>
        <td><%= i+1 %></td>
        <td><a href="/studentadministration/view/<%= d.id %>" style="color:var(--purple);font-weight:600"><%= d.first_name %> <%= d.last_name %></a></td>
        <td><%= d.admission_no %></td>
        <td><%= d.class_name||'—' %> <%= d.section||'' %></td>
        <td><%= d.father_name||'—' %></td>
        <td><%= d.father_mobile||'—' %></td>
        <td><span class="badge badge-red">₹0</span></td>
        <td><a href="/feemanagement/collect" class="btn btn-outline-purple btn-xs">Collect Fee</a></td>
      </tr>
      <% }) } else { %>
        <tr><td colspan="8" class="no-data" style="color:var(--green)">✅ No defaulters! All students have paid fee.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
