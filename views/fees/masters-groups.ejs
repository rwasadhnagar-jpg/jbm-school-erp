<%- include('../partials/header', { title: 'Fee Groups', activePage: 'fees' }) %>
<div class="page-header"><div><h1>💰 Fee Groups Master</h1></div></div>
<div class="dashboard-row col-2">
<div class="form-card">
  <div class="form-card-header">➕ Add Fee Group</div>
  <div class="form-card-body">
    <form method="POST" action="/feemanagement/masters/groups/add">
      <div class="form-group" style="margin-bottom:12px"><label>Group Name *</label><input type="text" name="name" class="form-control" required placeholder="e.g. Primary Fee Group"></div>
      <div class="form-group" style="margin-bottom:12px"><label>Class (Optional)</label>
        <select name="class_id" class="form-control">
          <option value="">All Classes</option>
          <% classes.forEach(c => { %><option value="<%= c.id %>"><%= c.class_name %> - <%= c.section %></option><% }) %>
        </select>
      </div>
      <div class="form-group" style="margin-bottom:12px"><label>Description</label><input type="text" name="description" class="form-control"></div>
      <button type="submit" class="btn btn-purple">Add Fee Group</button>
    </form>
  </div>
</div>
<div class="table-container">
  <div class="table-header"><h3>All Fee Groups</h3></div>
  <table><thead><tr><th>#</th><th>Group Name</th><th>Class</th></tr></thead>
  <tbody>
    <% if(groups.length) { groups.forEach((g,i) => { %>
    <tr><td><%= i+1 %></td><td><strong><%= g.name %></strong></td><td><%= g.class_name ? g.class_name+' '+g.section : 'All Classes' %></td></tr>
    <% }) } else { %>
    <tr><td colspan="3" class="no-data">No fee groups yet</td></tr>
    <% } %>
  </tbody></table>
</div>
</div>
<%- include('../partials/footer') %>
