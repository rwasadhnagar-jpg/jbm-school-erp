<%- include('../partials/header', { title: 'Fee Structure', activePage: 'fees' }) %>

<div class="page-header">
  <div><h1>📋 Fee Structure</h1><p class="page-sub">Set class-wise, head-wise fee amounts for AY 2026-27</p></div>
  <div>
    <a href="/feemanagement/masters/heads" class="btn btn-outline-purple">➕ Manage Fee Heads</a>
    <a href="/feemanagement" class="btn btn-outline-purple">← Fee Dashboard</a>
  </div>
</div>

<!-- CLASS SELECTOR -->
<div class="form-card" style="margin-bottom:20px">
  <div class="form-card-header">🏫 Select Class</div>
  <div class="form-card-body">
    <form method="GET" action="/feemanagement/structure" style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap">
      <div class="form-group" style="margin-bottom:0;flex:1;min-width:200px">
        <label>Class / Section</label>
        <select name="class_id" class="form-control" onchange="this.form.submit()">
          <option value="">-- Select Class --</option>
          <% classes.forEach(cls=>{ %>
          <option value="<%= cls.id %>" <%= selectedClass===cls.id?'selected':'' %>>
            Class <%= cls.class_name %> - <%= cls.section %>
          </option>
          <% }) %>
        </select>
      </div>
      <button type="submit" class="btn btn-purple">Load Fee Structure</button>
    </form>
  </div>
</div>

<% if(selectedClass && structure.length){ %>

<!-- FEE AMOUNT EDITOR -->
<form method="POST" action="/feemanagement/structure/save" id="structureForm">
  <input type="hidden" name="class_id" value="<%= selectedClass %>">

  <div class="form-card" style="margin-bottom:20px">
    <div class="form-card-header">
      💰 Fee Structure — <%= selectedClassName %>
      <span style="margin-left:10px;background:rgba(255,255,255,.2);padding:2px 10px;border-radius:12px;font-size:11px">AY 2026-2027</span>
    </div>
    <div class="form-card-body" style="padding:0">
      <table style="width:100%;border-collapse:collapse;font-size:14px">
        <thead>
          <tr style="background:#f0e6ff">
            <th style="padding:11px 14px;text-align:left;color:#4A0E8F;font-size:12px;border-bottom:2px solid #d0b8ff">Fee Head</th>
            <th style="padding:11px 14px;text-align:center;color:#4A0E8F;font-size:12px;border-bottom:2px solid #d0b8ff;width:130px">Type</th>
            <th style="padding:11px 14px;text-align:center;color:#4A0E8F;font-size:12px;border-bottom:2px solid #d0b8ff;width:100px">Late Fee</th>
            <th style="padding:11px 14px;text-align:right;color:#4A0E8F;font-size:12px;border-bottom:2px solid #d0b8ff;width:160px">Amount (₹)</th>
            <th style="padding:11px 14px;text-align:right;color:#4A0E8F;font-size:12px;border-bottom:2px solid #d0b8ff;width:140px">Annual Total</th>
          </tr>
        </thead>
        <tbody>
        <% let monthlyTotal=0,annualTotal=0; %>
        <% structure.forEach(row=>{ %>
          <% const amt=parseFloat(row.amount||0); %>
          <% if(row.fee_type==='Monthly') monthlyTotal+=amt*12; else annualTotal+=amt; %>
          <tr style="border-bottom:1px solid #f0e6ff" onmouseover="this.style.background='#faf5ff'" onmouseout="this.style.background=''">
            <td style="padding:10px 14px">
              <strong><%= row.head_name || row.name %></strong>
              <div style="font-size:11px;color:#888;margin-top:1px">
                <%= row.fee_type==='Monthly'?'Monthly × 12 months':'One-time per year' %>
              </div>
            </td>
            <td style="padding:10px 14px;text-align:center">
              <select name="fee_types[<%= row.fee_head_id||row.id %>]" class="form-control" style="font-size:12px;padding:4px 8px" onchange="recalcRow(this)">
                <option value="Monthly" <%= (row.fee_type||'Monthly')==='Monthly'?'selected':'' %>>Monthly</option>
                <option value="Annual" <%= row.fee_type==='Annual'?'selected':'' %>>Annual</option>
              </select>
            </td>
            <td style="padding:10px 14px;text-align:center">
              <label style="display:flex;align-items:center;justify-content:center;gap:6px;cursor:pointer;font-size:12px">
                <input type="checkbox" name="apply_late_fees[<%= row.fee_head_id||row.id %>]" value="1"
                  <%= row.apply_late_fee?'checked':'' %>
                  style="accent-color:#e65100;width:15px;height:15px">
                <span style="color:#e65100">₹10/day</span>
              </label>
            </td>
            <td style="padding:10px 14px;text-align:right">
              <input type="number" name="amounts[<%= row.fee_head_id||row.id %>]"
                class="form-control" style="text-align:right;font-size:15px;font-weight:700;color:#4A0E8F"
                value="<%= amt>0?amt:'' %>" min="0" step="1" placeholder="0"
                oninput="updateTotals()">
            </td>
            <td style="padding:10px 14px;text-align:right;font-weight:700;color:#555;font-size:13px" class="annual-col">
              <%= amt>0?(row.fee_type==='Monthly'?'₹'+Math.round(amt*12).toLocaleString('en-IN'):'₹'+Math.round(amt).toLocaleString('en-IN')):'—' %>
            </td>
          </tr>
        <% }) %>
        </tbody>
        <tfoot>
          <tr style="background:#4A0E8F;color:#fff">
            <td colspan="3" style="padding:11px 14px;font-weight:700">Total Annual Fee</td>
            <td style="padding:11px 14px;text-align:right;font-weight:700" id="grandTotalCell">
              —
            </td>
            <td style="padding:11px 14px;text-align:right;font-weight:700" id="grandAnnualCell">
              ₹<%= Math.round(monthlyTotal+annualTotal).toLocaleString('en-IN') %>
            </td>
          </tr>
        </tfoot>
      </table>
    </div>
    <div class="form-actions" style="display:flex;gap:12px;flex-wrap:wrap">
      <button type="submit" class="btn btn-purple">💾 Save Fee Structure</button>
      <button type="button" class="btn" style="background:#f0e6ff;color:#4A0E8F" onclick="document.getElementById('copyForm').style.display=document.getElementById('copyForm').style.display==='none'?'block':'none'">📋 Copy to Other Classes</button>
      <a href="/feemanagement/structure" class="btn btn-outline-purple">Cancel</a>
    </div>
  </div>
</form>

<!-- COPY STRUCTURE FORM -->
<div id="copyForm" style="display:none">
<form method="POST" action="/feemanagement/structure/copy">
  <input type="hidden" name="from_class_id" value="<%= selectedClass %>">
  <div class="form-card" style="border:2px solid #7B2FBE">
    <div class="form-card-header" style="background:#7B2FBE">📋 Copy Fee Structure to Other Classes</div>
    <div class="form-card-body">
      <p style="font-size:13px;color:#555;margin-bottom:12px">Copy the fee amounts from <strong><%= selectedClassName %></strong> to selected classes:</p>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;max-height:300px;overflow-y:auto">
        <% classes.filter(c=>c.id!==selectedClass).forEach(cls=>{ %>
        <label style="display:flex;align-items:center;gap:6px;padding:7px 10px;background:#f9f5ff;border-radius:6px;cursor:pointer;font-size:13px;border:1.5px solid #e8d8ff">
          <input type="checkbox" name="to_class_ids[]" value="<%= cls.id %>" style="accent-color:#4A0E8F">
          Class <%= cls.class_name %>-<%= cls.section %>
        </label>
        <% }) %>
      </div>
      <div style="margin-top:14px;display:flex;gap:10px">
        <button type="submit" class="btn btn-purple" onclick="return confirm('Copy fee structure to selected classes?')">✅ Copy Now</button>
        <button type="button" class="btn btn-outline-purple" onclick="document.getElementById('copyForm').style.display='none'">Cancel</button>
      </div>
    </div>
  </div>
</form>
</div>

<script>
function updateTotals() {
  let monthly = 0, annual = 0;
  document.querySelectorAll('tbody tr').forEach(row => {
    const amtInput = row.querySelector('input[type=number]');
    const typeSelect = row.querySelector('select');
    if (!amtInput || !typeSelect) return;
    const amt = parseFloat(amtInput.value) || 0;
    const type = typeSelect.value;
    const annualCell = row.querySelector('.annual-col');
    if (type === 'Monthly') {
      monthly += amt * 12;
      if (annualCell) annualCell.textContent = amt > 0 ? '₹' + Math.round(amt * 12).toLocaleString('en-IN') : '—';
    } else {
      annual += amt;
      if (annualCell) annualCell.textContent = amt > 0 ? '₹' + Math.round(amt).toLocaleString('en-IN') : '—';
    }
  });
  const grand = monthly + annual;
  document.getElementById('grandAnnualCell').textContent = '₹' + Math.round(grand).toLocaleString('en-IN');
}
updateTotals();
</script>

<% } else if(selectedClass && !structure.length) { %>
<div class="form-card">
  <div class="form-card-body" style="text-align:center;padding:30px;color:#aaa">
    No fee heads found. <a href="/feemanagement/masters/heads" style="color:#4A0E8F;font-weight:700">Create Fee Heads first →</a>
  </div>
</div>
<% } %>

<%- include('../partials/footer') %>
