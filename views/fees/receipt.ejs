<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Fee Receipt — <%= payment.receipt_no %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #e0e0e0; color: #222; }

    /* Screen: show two receipts side by side on A4 preview */
    .page-wrapper {
      width: 210mm;
      margin: 20px auto;
      background: #fff;
      border: 1px solid #ccc;
    }

    /* Each receipt = half of A4 = 148.5mm tall */
    .receipt {
      width: 100%;
      height: 148.5mm;
      border: 2px solid #4A0E8F;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      position: relative;
    }
    .receipt + .receipt {
      border-top: 3px dashed #4A0E8F;
    }

    /* School Header */
    .receipt-header {
      background: #fff;
      padding: 8px 14px 6px;
      border-bottom: 2px solid #4A0E8F;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }
    .receipt-header img { width: 52px; height: 52px; object-fit: contain; }
    .receipt-header-text { flex: 1; text-align: center; }
    .receipt-header h1 { font-size: 15px; font-weight: 800; color: #4A0E8F; letter-spacing: 0.5px; }
    .receipt-header h2 { font-size: 9.5px; color: #333; font-weight: 600; margin-top: 1px; }
    .receipt-header p  { font-size: 8.5px; color: #555; margin-top: 1px; line-height: 1.4; }

    /* Title bar */
    .receipt-title-bar {
      background: #4A0E8F;
      color: #fff;
      text-align: center;
      padding: 4px 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 3px;
      flex-shrink: 0;
    }

    .receipt-body { padding: 8px 14px 6px; flex: 1; display: flex; flex-direction: column; }

    /* Receipt No + Date */
    .receipt-meta {
      display: flex;
      justify-content: space-between;
      font-size: 10px;
      border-bottom: 1px dashed #ccc;
      padding-bottom: 5px;
      margin-bottom: 6px;
    }
    .receipt-meta span { font-weight: 700; color: #4A0E8F; }

    /* Info table */
    .info-table { width: 100%; border-collapse: collapse; margin-bottom: 6px; font-size: 10px; }
    .info-table td { padding: 3px 6px; border: 1px solid #e0e0e0; }
    .info-table td:first-child { background: #f7f3ff; font-weight: 600; color: #4A0E8F; width: 33%; }

    /* Amount row */
    .amount-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #f7f3ff;
      border: 1.5px solid #4A0E8F;
      border-radius: 5px;
      padding: 6px 10px;
      margin-bottom: 5px;
    }
    .amount-label { font-size: 10px; color: #555; }
    .amount-value { font-size: 22px; font-weight: 800; color: #4A0E8F; }
    .mode-badge { background: #4A0E8F; color: #fff; padding: 2px 10px; border-radius: 12px; font-size: 9px; font-weight: 700; }

    .remarks-row { font-size: 9.5px; color: #666; margin-bottom: 4px; }

    /* Footer */
    .receipt-footer {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      border-top: 1px dashed #ccc;
      padding-top: 5px;
      margin-top: auto;
      font-size: 9px;
      color: #888;
    }
    .sig-block { text-align: center; }
    .sig-line { border-top: 1px solid #aaa; width: 100px; margin: 18px auto 2px; }

    .watermark { text-align: center; font-size: 8px; color: #bbb; margin-top: 4px; }

    /* Print buttons (hidden on print) */
    .print-actions {
      text-align: center;
      padding: 14px;
      background: #f5f5f5;
      display: flex;
      gap: 10px;
      justify-content: center;
    }
    .btn-print { background: #4A0E8F; color: #fff; border: none; padding: 10px 28px; border-radius: 6px; font-size: 14px; cursor: pointer; font-weight: 600; }
    .btn-close  { background: #fff; color: #4A0E8F; border: 2px solid #4A0E8F; padding: 10px 24px; border-radius: 6px; font-size: 14px; cursor: pointer; font-weight: 600; }

    @media print {
      @page { size: A4 portrait; margin: 0; }
      body { background: #fff; }
      .print-actions { display: none; }
      .page-wrapper { margin: 0; border: none; width: 210mm; }
      .receipt { border-left: none; border-right: none; }
    }
  </style>
</head>
<body>

<div class="page-wrapper">
  <!-- TOP COPY (School Copy) -->
  <div class="receipt">
    <div class="receipt-header">
      <img src="/img/logo.png" alt="JBM Logo">
      <div class="receipt-header-text">
        <h1>JBM PUBLIC SCHOOL</h1>
        <h2>RZ 666/1, 3&4 Nasirpur Road, Sadh Nagar, Palam, New Delhi - 110045</h2>
        <p>Ph: 9868337627 | 9891251352 &nbsp;|&nbsp; jbmpschool@gmail.com &nbsp;|&nbsp; www.jbmpschool.com</p>
        <p>CBSE Affiliation No: <strong>2730708</strong> &nbsp;|&nbsp; School ID: <strong>1821201</strong></p>
      </div>
    </div>
    <div class="receipt-title-bar">FEE RECEIPT &nbsp;—&nbsp; SCHOOL COPY</div>
    <div class="receipt-body">
      <div class="receipt-meta">
        <div>Receipt No: <span><%= payment.receipt_no %></span></div>
        <div>Date: <span><%= new Date(payment.payment_date).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %></span></div>
      </div>
      <table class="info-table">
        <tr><td>Student Name</td><td><strong><%= payment.first_name %> <%= payment.last_name %></strong></td></tr>
        <tr><td>Admission No.</td><td><%= payment.admission_no || '—' %></td></tr>
        <tr><td>Class / Section</td><td><%= payment.class_name || '—' %> <%= payment.section || '' %></td></tr>
        <% if(payment.father_name) { %><tr><td>Father's Name</td><td><%= payment.father_name %></td></tr><% } %>
        <% if(payment.transaction_id) { %><tr><td>Txn / Cheque No.</td><td><%= payment.transaction_id %></td></tr><% } %>
      </table>
      <div class="amount-row">
        <div><div class="amount-label">Amount Paid</div><div class="amount-value">₹<%= Number(payment.amount_paid).toLocaleString('en-IN') %></div></div>
        <span class="mode-badge"><%= payment.payment_mode %></span>
      </div>
      <% if(payment.remarks) { %><div class="remarks-row"><strong>Remarks:</strong> <%= payment.remarks %></div><% } %>
      <div class="receipt-footer">
        <div><div>Collected by: <strong><%= payment.collected_by_name || 'Admin' %></strong></div><div style="margin-top:2px">Generated: <%= new Date().toLocaleDateString('en-IN') %></div></div>
        <div class="sig-block"><div class="sig-line"></div><div>Authorized Signatory</div></div>
      </div>
      <div class="watermark">Computer generated receipt</div>
    </div>
  </div>

  <!-- BOTTOM COPY (Student Copy) -->
  <div class="receipt">
    <div class="receipt-header">
      <img src="/img/logo.png" alt="JBM Logo">
      <div class="receipt-header-text">
        <h1>JBM PUBLIC SCHOOL</h1>
        <h2>RZ 666/1, 3&4 Nasirpur Road, Sadh Nagar, Palam, New Delhi - 110045</h2>
        <p>Ph: 9868337627 | 9891251352 &nbsp;|&nbsp; jbmpschool@gmail.com &nbsp;|&nbsp; www.jbmpschool.com</p>
        <p>CBSE Affiliation No: <strong>2730708</strong> &nbsp;|&nbsp; School ID: <strong>1821201</strong></p>
      </div>
    </div>
    <div class="receipt-title-bar">FEE RECEIPT &nbsp;—&nbsp; STUDENT COPY</div>
    <div class="receipt-body">
      <div class="receipt-meta">
        <div>Receipt No: <span><%= payment.receipt_no %></span></div>
        <div>Date: <span><%= new Date(payment.payment_date).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %></span></div>
      </div>
      <table class="info-table">
        <tr><td>Student Name</td><td><strong><%= payment.first_name %> <%= payment.last_name %></strong></td></tr>
        <tr><td>Admission No.</td><td><%= payment.admission_no || '—' %></td></tr>
        <tr><td>Class / Section</td><td><%= payment.class_name || '—' %> <%= payment.section || '' %></td></tr>
        <% if(payment.father_name) { %><tr><td>Father's Name</td><td><%= payment.father_name %></td></tr><% } %>
        <% if(payment.transaction_id) { %><tr><td>Txn / Cheque No.</td><td><%= payment.transaction_id %></td></tr><% } %>
      </table>
      <div class="amount-row">
        <div><div class="amount-label">Amount Paid</div><div class="amount-value">₹<%= Number(payment.amount_paid).toLocaleString('en-IN') %></div></div>
        <span class="mode-badge"><%= payment.payment_mode %></span>
      </div>
      <% if(payment.remarks) { %><div class="remarks-row"><strong>Remarks:</strong> <%= payment.remarks %></div><% } %>
      <div class="receipt-footer">
        <div><div>Collected by: <strong><%= payment.collected_by_name || 'Admin' %></strong></div><div style="margin-top:2px">Generated: <%= new Date().toLocaleDateString('en-IN') %></div></div>
        <div class="sig-block"><div class="sig-line"></div><div>Authorized Signatory</div></div>
      </div>
      <div class="watermark">Computer generated receipt</div>
    </div>
  </div>
</div>

<div class="print-actions">
  <button class="btn-print" onclick="window.print()">🖨️ Print Receipt</button>
  <button class="btn-close" onclick="window.close()">✕ Close</button>
</div>

</body>
</html>
