<%- include('../partials/header', { title: 'Collect Fee', activePage: 'fees' }) %>
<div class="page-header"><div><h1>💰 Collect Fee</h1><div class="breadcrumb"><a href="/feemanagement" style="color:rgba(255,255,255,0.8)">Fee</a> → Collect</div></div></div>

<div class="form-card" style="max-width:600px">
  <div class="form-card-header">🧾 Fee Collection Form</div>
  <div class="form-card-body">
    <form method="POST" action="/feemanagement/collect">
      <div class="form-group" style="margin-bottom:14px">
        <label>Select Student <span class="required">*</span></label>
        <select name="student_id" class="form-control" required>
          <option value="">-- Search Student --</option>
          <% students.forEach(s => { %><option value="<%= s.id %>"><%= s.first_name %> <%= s.last_name %> | <%= s.admission_no %> | <%= s.class_name||'' %> <%= s.section||'' %></option><% }) %>
        </select>
      </div>
      <div class="form-group" style="margin-bottom:14px">
        <label>Amount (₹) <span class="required">*</span></label>
        <input type="number" name="amount_paid" class="form-control" required min="1" placeholder="Enter amount">
      </div>
      <div class="form-group" style="margin-bottom:14px">
        <label>Payment Date <span class="required">*</span></label>
        <input type="date" name="payment_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>" required>
      </div>
      <div class="form-group" style="margin-bottom:14px">
        <label>Payment Mode</label>
        <select name="payment_mode" class="form-control">
          <option>Cash</option><option>Cheque</option><option>Online</option><option>UPI</option><option>DD</option>
        </select>
      </div>
      <div class="form-group" style="margin-bottom:14px">
        <label>Transaction ID / Cheque No.</label>
        <input type="text" name="transaction_id" class="form-control" placeholder="Optional">
      </div>
      <div class="form-group" style="margin-bottom:14px">
        <label>Remarks</label>
        <textarea name="remarks" class="form-control" rows="2" placeholder="Optional"></textarea>
      </div>
      <div style="display:flex;gap:10px;margin-top:8px">
        <button type="submit" class="btn btn-purple">💾 Collect & Save</button>
        <a href="/feemanagement" class="btn btn-outline-purple">Cancel</a>
      </div>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
