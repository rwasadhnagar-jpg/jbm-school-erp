<%- include('../partials/header', { title: 'Online Payments', activePage: 'fees' }) %>

<div class="page-header">
  <div>
    <h1>📱 Online Payment Requests</h1>
    <p class="page-sub">Fee payments submitted by students from the portal — verify UTR and confirm</p>
  </div>
  <div>
    <% if(pendingCount>0){ %>
    <span style="background:#ff9800;color:#fff;padding:6px 14px;border-radius:20px;font-weight:700;font-size:13px">⏳ <%= pendingCount %> Pending</span>
    <% } %>
    <a href="/feemanagement" class="btn btn-outline-purple">← Fee Dashboard</a>
  </div>
</div>

<!-- FILTER BAR -->
<div class="filter-bar" style="margin-bottom:16px">
  <a href="/feemanagement/online" class="btn <%= !filterStatus?'btn-purple':'btn-outline-purple' %>">All (<%= onlinePayments.length %>)</a>
  <a href="/feemanagement/online?status=Pending" class="btn <%= filterStatus==='Pending'?'btn-purple':'btn-outline-purple' %>" style="background:<%= filterStatus==='Pending'?'#ff9800':'#fff' %>;border-color:#ff9800;color:<%= filterStatus==='Pending'?'#fff':'#e65100' %>">⏳ Pending (<%= pendingCount %>)</a>
  <a href="/feemanagement/online?status=Verified" class="btn" style="background:<%= filterStatus==='Verified'?'#4caf50':'#fff' %>;border:1.5px solid #4caf50;color:<%= filterStatus==='Verified'?'#fff':'#2e7d32' %>">✅ Verified</a>
  <a href="/feemanagement/online?status=Rejected" class="btn" style="background:<%= filterStatus==='Rejected'?'#f44336':'#fff' %>;border:1.5px solid #f44336;color:<%= filterStatus==='Rejected'?'#fff':'#c62828' %>">❌ Rejected</a>
</div>

<% if(pendingCount>0){ %>
<div style="background:#fff8e1;border:1px solid #ffe082;border-radius:8px;padding:10px 14px;margin-bottom:14px;font-size:13px;color:#666">
  💡 <strong>How to verify:</strong> Check the UTR number against your bank/UPI app transaction history, then click <strong>Verify</strong> to confirm the payment. Verified payments are added to the fee collection report automatically.
</div>
<% } %>

<div class="table-card">
  <table class="data-table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Receipt No</th>
        <th>Student</th>
        <th>Class</th>
        <th>Fee Amt</th>
        <th>Late Fee</th>
        <th>Total</th>
        <th>UTR / Txn ID</th>
        <th>Fee Details</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(!onlinePayments.length){ %>
      <tr><td colspan="11" style="text-align:center;padding:30px;color:#aaa">No online payments found</td></tr>
      <% } %>
      <% onlinePayments.forEach(p=>{ %>
      <%
        let feeLines = [];
        try { feeLines = JSON.parse(p.fee_details || '[]'); } catch(e){}
      %>
      <tr>
        <td style="font-size:12px"><%= new Date(p.created_at).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %><br><span style="color:#aaa"><%= new Date(p.created_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) %></span></td>
        <td style="font-family:monospace;font-size:12px"><%= p.receipt_no %></td>
        <td>
          <strong><%= p.first_name %> <%= p.last_name %></strong><br>
          <span style="font-size:12px;color:#888">Adm: <%= p.admission_no %></span>
        </td>
        <td style="font-size:13px"><%= p.class_name %> - <%= p.section %></td>
        <td style="font-weight:600;color:#4A0E8F">₹<%= Number(p.fee_amount||0).toLocaleString('en-IN') %></td>
        <td style="color:#e65100;font-size:12px"><%= p.late_fee>0?'₹'+Number(p.late_fee).toLocaleString('en-IN'):'—' %></td>
        <td style="font-size:16px;font-weight:800;color:#4A0E8F">₹<%= Number(p.total_amount).toLocaleString('en-IN') %></td>
        <td>
          <span style="font-family:monospace;font-size:12px;font-weight:700;color:#333"><%= p.utr_no %></span>
        </td>
        <td style="font-size:11px;max-width:180px">
          <% if(feeLines.length){ %>
          <div style="max-height:60px;overflow-y:auto">
            <% feeLines.slice(0,3).forEach(fl=>{ %>
            <div style="color:#555"><%= fl.head %> <%= fl.type==='Annual'?'(Annual)':(fl.month+' '+fl.year) %></div>
            <% }) %>
            <% if(feeLines.length>3){ %><div style="color:#aaa">+<%= feeLines.length-3 %> more</div><% } %>
          </div>
          <% } else { %><span style="color:#aaa">—</span><% } %>
        </td>
        <td>
          <% if(p.status==='Verified'){ %>
            <span style="background:#e8f5e9;color:#2e7d32;padding:4px 10px;border-radius:12px;font-size:11px;font-weight:700">✅ Verified</span>
          <% } else if(p.status==='Rejected'){ %>
            <span style="background:#ffebee;color:#c62828;padding:4px 10px;border-radius:12px;font-size:11px;font-weight:700">❌ Rejected</span>
          <% } else { %>
            <span style="background:#fff3e0;color:#e65100;padding:4px 10px;border-radius:12px;font-size:11px;font-weight:700">⏳ Pending</span>
          <% } %>
        </td>
        <td>
          <div style="display:flex;flex-direction:column;gap:4px">
            <a href="/portal/pay/receipt/<%= p.id %>?admin=1" target="_blank" class="btn btn-outline-purple" style="font-size:11px;padding:3px 8px;text-align:center">🖨️ Receipt</a>
            <% if(p.status==='Pending'){ %>
            <form method="POST" action="/feemanagement/online/verify/<%= p.id %>" style="margin:0" onsubmit="return confirm('Verify UTR <%= p.utr_no %> — ₹<%= Number(p.total_amount).toLocaleString('en-IN') %>?')">
              <button type="submit" class="btn" style="width:100%;background:#4caf50;color:#fff;font-size:11px;padding:3px 8px">✅ Verify</button>
            </form>
            <form method="POST" action="/feemanagement/online/reject/<%= p.id %>" style="margin:0" onsubmit="return confirm('Reject this payment?')">
              <button type="submit" class="btn" style="width:100%;background:#f44336;color:#fff;font-size:11px;padding:3px 8px">❌ Reject</button>
            </form>
            <% } %>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
