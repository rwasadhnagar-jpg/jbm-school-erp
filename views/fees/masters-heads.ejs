<%- include('../partials/header', { title: 'Fee Heads', activePage: 'fees' }) %>
<div class="page-header"><div><h1>💰 Fee Heads Master</h1></div></div>
<div class="dashboard-row col-2">
<div class="form-card">
  <div class="form-card-header">➕ Add Fee Head</div>
  <div class="form-card-body">
    <form method="POST" action="/feemanagement/masters/heads/add">
      <div class="form-group" style="margin-bottom:12px"><label>Fee Head Name *</label><input type="text" name="name" class="form-control" required placeholder="e.g. Tuition Fee"></div>
      <div class="form-group" style="margin-bottom:12px"><label>Description</label><input type="text" name="description" class="form-control"></div>
      <button type="submit" class="btn btn-purple">Add Fee Head</button>
    </form>
  </div>
</div>
<div class="table-container">
  <div class="table-header"><h3>All Fee Heads</h3></div>
  <table><thead><tr><th>#</th><th>Name</th><th>Status</th><th>Action</th></tr></thead>
  <tbody>
    <% heads.forEach((h,i) => { %>
    <tr><td><%= i+1 %></td><td><strong><%= h.name %></strong></td>
    <td><% if(h.is_active) { %><span class="badge badge-green">Active</span><% } else { %><span class="badge badge-grey">Inactive</span><% } %></td>
    <td><form method="POST" action="/feemanagement/masters/heads/delete/<%= h.id %>" style="display:inline" onsubmit="return confirm('Remove this fee head?')"><button class="btn btn-outline-red btn-xs">Remove</button></form></td></tr>
    <% }) %>
  </tbody></table>
</div>
</div>
<%- include('../partials/footer') %>
